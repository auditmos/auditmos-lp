---
import Layout from "@/layouts/Layout.astro";
import type { ServicePage } from "@/site/pages";

interface Section {
	heading: string;
	body: string;
}

interface Props {
	page: ServicePage;
	headline: string;
	intro: string;
	bestFor: readonly string[];
	sections: readonly Section[];
	deliverables: readonly string[];
}

const { page, headline, intro, bestFor, sections, deliverables } = Astro.props;
---

<Layout title={page.title} description={page.description} path={page.path} schema={page.jsonLd}>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 lg:grid-cols-[1fr_0.8fr] lg:py-20">
				<div>
					<p class="mb-4 font-medium text-brand-accent text-sm uppercase tracking-[0.18em]">
						{page.jsonLd.name}
					</p>
					<h1 class="max-w-4xl text-4xl font-semibold text-white leading-tight sm:text-5xl">
						{headline}
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-neutral-300 leading-8">{intro}</p>
				</div>
				<div class="rounded-lg border border-neutral-800 bg-neutral-900/70 p-6">
					<h2 class="font-semibold text-white text-xl">Best fit</h2>
					<ul class="mt-5 grid gap-3 text-neutral-300 text-sm leading-6">
						{bestFor.map((item) => <li class="border-neutral-800 border-b pb-3 last:border-0">{item}</li>)}
					</ul>
				</div>
			</div>
		</section>

		<section class="border-neutral-800 border-b bg-neutral-900/40">
			<div class="mx-auto grid max-w-6xl gap-6 px-6 py-14 md:grid-cols-3">
				{
					sections.map((section) => (
						<article>
							<h2 class="text-2xl font-semibold text-white">{section.heading}</h2>
							<p class="mt-4 text-neutral-300 leading-7">{section.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section>
			<div class="mx-auto max-w-6xl px-6 py-14">
				<h2 class="text-3xl font-semibold text-white">Typical deliverables</h2>
				<ul class="mt-6 grid gap-3 md:grid-cols-2">
					{
						deliverables.map((item) => (
							<li class="rounded-lg border border-neutral-800 bg-neutral-900/60 p-4 text-neutral-300">
								{item}
							</li>
						))
					}
				</ul>
			</div>
		</section>
	</main>
</Layout>
