---
import Layout from "@/layouts/Layout.astro";
import type { ServicePage } from "@/site/pages";

interface Section {
	heading: string;
	body: string;
}

interface Props {
	page: ServicePage;
	headline: string;
	intro: string;
	bestFor: readonly string[];
	sections: readonly Section[];
	deliverables: readonly string[];
}

const { page, headline, intro, bestFor, sections, deliverables } = Astro.props;
---

<Layout title={page.title} description={page.description} path={page.path} schema={page.jsonLd}>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-7xl lg:grid-cols-[1.3fr_0.7fr]">
				<div class="px-5 py-16 sm:px-8 sm:py-24 lg:border-neutral-800 lg:border-r lg:py-28">
					<p class="font-mono text-brand-accent text-xs uppercase">Expertise / {page.jsonLd.name}</p>
					<h1 class="mt-7 max-w-5xl text-balance font-semibold text-5xl text-white leading-[1.03] sm:text-7xl">
						{headline}
					</h1>
					<p class="mt-8 max-w-3xl text-pretty text-lg text-neutral-300 leading-8 sm:text-xl">{intro}</p>
					<div class="mt-10 flex flex-col gap-3 sm:flex-row">
						<a
							class="inline-flex items-center justify-center gap-2 rounded-sm bg-brand-accent px-5 py-3.5 font-semibold text-neutral-950 hover:bg-white"
							href="/contact"
						>
							Discuss your project <span aria-hidden="true">↗</span>
						</a>
						<a
							class="inline-flex items-center justify-center rounded-sm border border-neutral-700 px-5 py-3.5 font-semibold text-white hover:border-neutral-500 hover:bg-neutral-900"
							href="/projects"
						>
							View related work
						</a>
					</div>
				</div>

				<aside class="bg-neutral-900/40 p-5 sm:p-8 lg:flex lg:flex-col lg:justify-end lg:py-12">
					<p class="font-mono text-brand-accent text-xs uppercase">Strong fit when</p>
					<ul class="mt-6 border-neutral-800 border-t">
						{
							bestFor.map((item, index) => (
								<li class="grid grid-cols-[2rem_1fr] gap-3 border-neutral-800 border-b py-5 text-pretty text-neutral-300 text-sm leading-6">
									<span class="font-mono text-neutral-600 tabular-nums">0{index + 1}</span>
									{item}
								</li>
							))
						}
					</ul>
				</aside>
			</div>
		</section>

		<section class="border-neutral-800 border-b">
			<div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-24">
				<div class="grid gap-8 lg:grid-cols-[0.5fr_1.5fr] lg:gap-16">
					<div>
						<p class="font-mono text-brand-accent text-xs uppercase">How we help</p>
						<h2 class="mt-4 text-balance font-semibold text-3xl text-white sm:text-4xl">A focused path from question to action.</h2>
					</div>
					<div class="border-neutral-800 border-t">
						{
							sections.map((section, index) => (
								<article class="grid gap-4 border-neutral-800 border-b py-7 sm:grid-cols-[3rem_0.65fr_1.35fr] sm:px-4">
									<span class="font-mono text-brand-accent text-xs tabular-nums">0{index + 1}</span>
									<h3 class="text-balance font-semibold text-white text-xl">{section.heading}</h3>
									<p class="max-w-xl text-pretty text-neutral-400 leading-7">{section.body}</p>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="border-neutral-800 border-b bg-neutral-900/30">
			<div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[0.75fr_1.25fr] lg:gap-20">
				<div>
					<p class="font-mono text-brand-accent text-xs uppercase">What you leave with</p>
					<h2 class="mt-4 max-w-lg text-balance font-semibold text-3xl text-white sm:text-5xl">Useful artifacts, not a black box.</h2>
					<p class="mt-6 max-w-lg text-pretty text-neutral-400 leading-7">
						The output is designed to keep working after the engagement—inside engineering,
						leadership, procurement, or review.
					</p>
				</div>
				<ul class="border-neutral-800 border-t">
					{
						deliverables.map((item) => (
							<li class="grid grid-cols-[1.5rem_1fr] gap-4 border-neutral-800 border-b py-5 text-pretty text-neutral-300 leading-7">
								<span class="text-brand-accent" aria-hidden="true">✓</span>
								{item}
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section>
			<div class="mx-auto flex max-w-7xl flex-col gap-7 px-5 py-16 sm:px-8 sm:py-20 lg:flex-row lg:items-center lg:justify-between">
				<h2 class="max-w-3xl text-balance font-semibold text-3xl text-white sm:text-5xl">Have a real problem in this territory?</h2>
				<a class="inline-flex items-center gap-2 font-semibold text-brand-accent hover:text-white" href="/contact">
					Tell us what is at stake <span aria-hidden="true">→</span>
				</a>
			</div>
		</section>
	</main>
</Layout>
