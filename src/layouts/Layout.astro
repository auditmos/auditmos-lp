---
import {
	buildCloudflareAnalyticsScript,
	legalEntity,
	navigationItems,
	site,
} from "@/brand/site";
import "@/styles/globals.css";
import iconUrl from "@/assets/logos/auditmos-icon-transparent.svg?url";

interface Props {
	title?: string;
	description?: string;
}

const { title = site.defaultTitle, description = site.defaultDescription } = Astro.props;
const analyticsScript = buildCloudflareAnalyticsScript(
	import.meta.env.CLOUDFLARE_WEB_ANALYTICS_TOKEN,
);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<link rel="icon" type="image/svg+xml" href={iconUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{analyticsScript && <Fragment set:html={analyticsScript} />}
	</head>
	<body class="min-h-screen bg-neutral-950 font-sans text-neutral-100 antialiased">
		<header class="border-neutral-800 border-b">
			<div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-5">
				<a class="font-semibold text-lg text-white" href="/" aria-label={`${site.name} home`}>
					{site.name}
				</a>
				<nav aria-label="Primary navigation">
					<ul class="flex items-center gap-5 text-neutral-300 text-sm">
						{
							navigationItems.map((item) => (
								<li>
									<a class="transition hover:text-brand-accent" href={item.href}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>
		</header>
		<slot />
		<footer class="border-neutral-800 border-t">
			<div class="mx-auto max-w-6xl px-6 py-8 text-neutral-400 text-sm">
				<p>
					{legalEntity.name} · Registration {legalEntity.registration} · VAT {legalEntity.vat} · {
						legalEntity.address
					}
				</p>
			</div>
		</footer>
	</body>
</html>
