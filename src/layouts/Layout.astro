---
import {
	buildCloudflareAnalyticsScript,
	legalEntity,
	navigationItems,
	organizationJsonLd,
	site,
} from "@/brand/site";
import "@/styles/globals.css";
import iconUrl from "@/assets/logos/auditmos-icon-transparent.svg?url";

interface Props {
	title?: string;
	description?: string;
	path?: "/" | `/${string}`;
	schema?: unknown | readonly unknown[];
}

const {
	title = site.defaultTitle,
	description = site.defaultDescription,
	path = "/",
	schema = [],
} = Astro.props;
const analyticsScript = buildCloudflareAnalyticsScript(
	import.meta.env.CLOUDFLARE_WEB_ANALYTICS_TOKEN,
);
const canonicalUrl = new URL(path, `${site.url}/`).toString();
const extraSchemas = Array.isArray(schema) ? schema : [schema];
const jsonLdItems = [organizationJsonLd, ...extraSchemas];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href={iconUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{
			jsonLdItems.map((item) => (
				<script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
			))
		}
		{analyticsScript && <Fragment set:html={analyticsScript} />}
	</head>
	<body class="min-h-screen bg-neutral-950 font-sans text-neutral-100 antialiased">
		<header class="border-neutral-800 border-b">
			<div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
				<a class="font-semibold text-lg text-white" href="/" aria-label={`${site.name} home`}>
					{site.name}
				</a>
				<nav aria-label="Primary navigation">
					<ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-neutral-300 text-sm">
						{
							navigationItems.map((item) => (
								<li>
									<a class="transition hover:text-brand-accent" href={item.href}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>
		</header>
		<slot />
		<footer class="border-neutral-800 border-t">
			<div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-8 text-neutral-400 text-sm md:flex-row md:items-center md:justify-between">
				<p>
					{legalEntity.name} · Registration {legalEntity.registration} · VAT {legalEntity.vat} · {
						legalEntity.address
					}
				</p>
				<p class="flex flex-wrap gap-x-4 gap-y-2">
					<a class="transition hover:text-brand-accent" href={`mailto:${site.contactEmail}`}>
						{site.contactEmail}
					</a>
					<a class="transition hover:text-brand-accent" href="/privacy">Privacy</a>
				</p>
			</div>
		</footer>
	</body>
</html>
