---
import {
	buildCloudflareAnalyticsScript,
	legalEntity,
	navigationItems,
	organizationJsonLd,
	site,
} from "@/brand/site";
import "@/styles/globals.css";
import fullLogoUrl from "@/assets/logos/auditmos-full-logo-transparent.svg?url";
import iconUrl from "@/assets/logos/auditmos-icon-transparent.svg?url";

interface Props {
	title?: string;
	description?: string;
	path?: "/" | `/${string}`;
	schema?: unknown | readonly unknown[];
}

const {
	title = site.defaultTitle,
	description = site.defaultDescription,
	path = "/",
	schema = [],
} = Astro.props;
const analyticsScript = buildCloudflareAnalyticsScript(
	import.meta.env.CLOUDFLARE_WEB_ANALYTICS_TOKEN,
);
const canonicalUrl = new URL(path, `${site.url}/`).toString();
const extraSchemas = Array.isArray(schema) ? schema : [schema];
const jsonLdItems = [organizationJsonLd, ...extraSchemas];
const footerServiceLinks = navigationItems.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href={iconUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{
			jsonLdItems.map((item) => (
				<script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
			))
		}
		{analyticsScript && <Fragment set:html={analyticsScript} />}
	</head>
	<body class="min-h-screen bg-neutral-950 font-sans text-neutral-100 antialiased">
		<a
			class="fixed top-3 left-3 z-50 -translate-y-20 bg-brand-accent px-4 py-2 font-semibold text-neutral-950 focus:translate-y-0"
			href="#main-content"
		>
			Skip to content
		</a>
		<header class="sticky top-0 z-40 border-neutral-800 border-b bg-neutral-950/95">
			<div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 sm:px-8">
				<a class="inline-flex items-center" href="/" aria-label={`${site.name} home`}>
					<img class="h-auto w-36" src={fullLogoUrl} alt="Auditmos" />
				</a>

				<div class="hidden items-center gap-7 lg:flex">
					<nav aria-label="Primary navigation">
						<ul class="flex items-center gap-6 text-neutral-300 text-sm">
							{
								navigationItems.map((item) => (
									<li>
										<a
											class:list={[
												"rounded-sm py-2 hover:text-white",
												path === item.href && "text-brand-accent",
											]}
											href={item.href}
										>
											{item.label}
										</a>
									</li>
								))
							}
						</ul>
					</nav>
					<a
						class="inline-flex items-center gap-2 rounded-sm bg-brand-accent px-4 py-2.5 font-semibold text-neutral-950 text-sm hover:bg-white"
						href="/contact"
					>
						Start a conversation <span aria-hidden="true">↗</span>
					</a>
				</div>

				<details class="group relative lg:hidden">
					<summary class="flex cursor-pointer list-none items-center gap-2 rounded-sm border border-neutral-700 px-3 py-2 text-sm text-white marker:content-none">
						Menu
						<svg class="size-4" aria-hidden="true" viewBox="0 0 16 16" fill="none">
							<path d="M2 5h12M2 11h12" stroke="currentColor" stroke-width="1.5" />
						</svg>
					</summary>
					<nav
						class="absolute top-12 right-0 w-64 border border-neutral-700 bg-neutral-950 p-2 shadow-xl"
						aria-label="Mobile navigation"
					>
						<ul class="grid text-sm">
						{
							navigationItems.map((item) => (
								<li>
									<a
										class:list={[
											"block rounded-sm px-3 py-3 text-neutral-200 hover:bg-neutral-900 hover:text-white",
											path === item.href && "text-brand-accent",
										]}
										href={item.href}
									>
										{item.label}
									</a>
								</li>
							))
						}
							<li class="mt-2 border-neutral-800 border-t pt-2">
								<a class="block bg-brand-accent px-3 py-3 font-semibold text-neutral-950" href="/contact">
									Start a conversation
								</a>
							</li>
						</ul>
					</nav>
				</details>
			</div>
		</header>
		<div id="main-content">
			<slot />
		</div>
		<footer class="border-neutral-800 border-t bg-neutral-900/40">
			<div class="mx-auto grid max-w-7xl gap-10 px-5 py-12 sm:px-8 lg:grid-cols-[1.4fr_0.8fr_0.8fr] lg:py-16">
				<div>
					<img class="h-auto w-36" src={fullLogoUrl} alt="Auditmos" />
					<p class="mt-5 max-w-md text-pretty text-neutral-400 text-sm leading-6">
						The independent technical practice of Tomasz Kowalczyk — senior software delivery,
						security audits with public reports, and applied R&D.
					</p>
				</div>
				<div>
					<p class="font-mono text-neutral-500 text-xs uppercase">Expertise</p>
					<ul class="mt-4 grid gap-3 text-neutral-300 text-sm">
						{footerServiceLinks.map((item) => <li><a class="hover:text-brand-accent" href={item.href}>{item.label}</a></li>)}
					</ul>
				</div>
				<div>
					<p class="font-mono text-neutral-500 text-xs uppercase">Explore</p>
					<ul class="mt-4 grid gap-3 text-neutral-300 text-sm">
						<li><a class="hover:text-brand-accent" href="/projects">Selected work</a></li>
						<li><a class="hover:text-brand-accent" href="/open-source">Open source</a></li>
						<li><a class="hover:text-brand-accent" href="/partners">Agency partners</a></li>
						<li><a class="hover:text-brand-accent" href="/about">Company</a></li>
						<li><a class="hover:text-brand-accent" href="/privacy">Privacy</a></li>
					</ul>
				</div>
			</div>
			<div class="border-neutral-800 border-t">
				<div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 py-6 text-neutral-500 text-xs sm:px-8 lg:flex-row lg:items-center lg:justify-between">
					<p>{legalEntity.name} · Reg {legalEntity.registration} · VAT {legalEntity.vat}</p>
					<div class="flex flex-col gap-2 sm:flex-row sm:gap-5">
						<a class="hover:text-brand-accent" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
						<p>{legalEntity.address}</p>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
