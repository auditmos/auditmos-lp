---
import Layout from "@/layouts/Layout.astro";
import { legalEntity } from "@/brand/site";
import { privacyPage } from "@/site/pages";

export const prerender = true;
---

<Layout title={privacyPage.title} description={privacyPage.description} path={privacyPage.path}>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-24 lg:py-28">
				<p class="font-mono text-brand-accent text-xs uppercase">Privacy</p>
				<h1 class="mt-7 max-w-5xl text-balance font-semibold text-5xl text-white leading-[1.03] sm:text-7xl">
					How Auditmos handles site and contact form data.
				</h1>
				<p class="mt-8 max-w-3xl text-pretty text-lg text-neutral-300 leading-8">
					This page covers the baseline GDPR information for visitors and people who contact
					Auditmos through the website. Auditmos is operated by {legalEntity.name}, registered
					in Estonia.
				</p>
			</div>
		</section>

		<section>
			<div class="mx-auto grid max-w-7xl gap-12 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[0.45fr_1.55fr]">
				<div>
					<p class="font-mono text-neutral-500 text-xs uppercase">Last reviewed</p>
					<p class="mt-2 text-neutral-300 text-sm tabular-nums">11 July 2026</p>
				</div>
				<div class="border-neutral-800 border-t">
				{
					privacyPage.sections.map((section, index) => (
						<article class="grid gap-5 border-neutral-800 border-b py-7 sm:grid-cols-[3rem_0.7fr_1.3fr]">
							<span class="font-mono text-brand-accent text-xs tabular-nums">0{index + 1}</span>
							<h2 class="text-balance font-semibold text-white text-xl">{section.heading}</h2>
							<div class="grid gap-3 text-pretty text-neutral-400 leading-7">
								{section.body.map((paragraph) => <p>{paragraph}</p>)}
							</div>
						</article>
					))
				}
				</div>
			</div>
		</section>
	</main>
</Layout>
