---
import { site } from "@/brand/site";
import iconUrl from "@/assets/logos/auditmos-icon-transparent.svg?url";
import fullLogoUrl from "@/assets/logos/auditmos-full-logo-transparent.svg?url";
import Layout from "@/layouts/Layout.astro";

export const prerender = true;
---

<Layout title={site.defaultTitle} description={site.defaultDescription}>
	<main>
		<section class="mx-auto grid min-h-[calc(100svh-13rem)] max-w-6xl items-center gap-12 px-6 py-16 lg:grid-cols-[1.15fr_0.85fr]">
			<div>
				<img class="mb-10 h-auto w-60 sm:w-72" src={fullLogoUrl} alt="Auditmos" />
				<p class="mb-4 font-medium text-brand-accent text-sm uppercase tracking-[0.18em]">
					Deployable brand skeleton
				</p>
				<h1 class="max-w-4xl text-4xl font-semibold text-white leading-tight sm:text-6xl">
					Auditmos: Security, Software Development & R&D
				</h1>
				<p class="mt-6 max-w-2xl text-lg text-neutral-300 leading-8">
					A static-first foundation for the new Auditmos site, wired for Cloudflare Workers,
					staging deploys, brand assets, and legal footer requirements.
				</p>
			</div>
			<div class="flex justify-start lg:justify-end" aria-hidden="true">
				<div class="grid size-52 place-items-center border border-brand-accent/40 bg-neutral-900/60 sm:size-72">
					<img class="size-28 sm:size-40" src={iconUrl} alt="" />
				</div>
			</div>
		</section>
	</main>
</Layout>
