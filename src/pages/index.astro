---
import fullLogoUrl from "@/assets/logos/auditmos-full-logo-transparent.svg?url";
import Layout from "@/layouts/Layout.astro";
import { homePage, servicePages } from "@/site/pages";

export const prerender = true;
---

<Layout title={homePage.title} description={homePage.description} path={homePage.path}>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-6xl gap-10 px-6 py-10 lg:grid-cols-[1.1fr_0.9fr] lg:py-14">
				<div>
					<img class="mb-8 h-auto w-56 sm:w-72" src={fullLogoUrl} alt="Auditmos" />
					<p class="mb-4 font-medium text-brand-accent text-sm uppercase tracking-[0.18em]">
						Security, software development, and R&D
					</p>
					<h1 class="max-w-4xl text-4xl font-semibold text-white leading-tight sm:text-5xl">
						Defensible software work for teams that need substance before scale.
					</h1>
					<p class="mt-6 max-w-2xl text-lg text-neutral-300 leading-8">
						Auditmos helps EU-based founders, CTOs, CISOs, and research teams ship reliable
						software, validate technical bets, and document security risk clearly enough for
						procurement, grants, and executive review.
					</p>
				</div>
				<div class="grid gap-4 self-end">
					{
						servicePages.map((service) => (
							<a
								class="rounded-lg border border-neutral-800 bg-neutral-900/70 p-5 transition hover:border-brand-accent/70"
								href={service.path}
							>
								<h2 class="font-semibold text-white text-xl">{service.jsonLd.name}</h2>
								<p class="mt-3 text-neutral-300 text-sm leading-6">{service.description}</p>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<section class="border-neutral-800 border-b bg-neutral-900/40">
			<div class="mx-auto grid max-w-6xl gap-8 px-6 py-14 md:grid-cols-3">
				<div>
					<p class="font-medium text-brand-accent text-sm uppercase tracking-[0.18em]">How we work</p>
					<h2 class="mt-3 text-3xl font-semibold text-white">Senior, direct, and evidence-led.</h2>
				</div>
				<div class="md:col-span-2">
					<p class="text-neutral-300 leading-8">
						The site is intentionally narrow because the work is usually introduced by referral,
						partner conversation, or procurement review. These pages are built to answer the
						next question fast: what Auditmos does, where the company is registered, and what
						kind of technical work it can credibly carry.
					</p>
				</div>
			</div>
		</section>

		<section>
			<div class="mx-auto max-w-6xl px-6 py-14">
				<div class="grid gap-6 rounded-lg border border-neutral-800 bg-neutral-900/60 p-6 md:grid-cols-[0.8fr_1.2fr]">
					<div>
						<p class="font-medium text-brand-accent text-sm uppercase tracking-[0.18em]">
							Featured projects
						</p>
						<h2 class="mt-3 text-3xl font-semibold text-white">Case studies land next.</h2>
					</div>
					<p class="text-neutral-300 leading-8">
						This area is reserved for the project collection in the next phase: named work where
						permission exists, anonymised sector case studies where confidentiality applies, and
						clear summaries of outcomes, stack, and delivery context.
					</p>
				</div>
			</div>
		</section>
	</main>
</Layout>
