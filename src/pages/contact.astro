---
import Layout from "@/layouts/Layout.astro";
import { contactPage } from "@/site/pages";

export const prerender = true;

const turnstileSiteKey =
	import.meta.env.TURNSTILE_SITE_KEY ?? "1x00000000000000000000AA";
---

<Layout title={contactPage.title} description={contactPage.description} path={contactPage.path}>
	<main>
		<section>
			<div class="mx-auto grid max-w-7xl lg:grid-cols-[0.85fr_1.15fr]">
				<div class="px-5 py-16 sm:px-8 sm:py-24 lg:border-neutral-800 lg:border-r lg:py-28">
					<p class="font-mono text-brand-accent text-xs uppercase">Start a conversation</p>
					<h1 class="mt-7 max-w-3xl text-balance font-semibold text-5xl text-white leading-[1.03] sm:text-7xl">
						What needs to be built, tested, or made clear?
					</h1>
					<p class="mt-8 max-w-2xl text-pretty text-lg text-neutral-300 leading-8">
						A useful first message names the system or idea, the decision in front of you, and
						any timing or constraints already known.
					</p>
					<div class="mt-10 border-neutral-800 border-t pt-6">
						<p class="font-mono text-neutral-500 text-xs uppercase">Prefer email?</p>
						<a class="mt-2 inline-block text-brand-accent hover:text-white" href="mailto:contact@auditmos.com">contact@auditmos.com ↗</a>
					</div>
				</div>

				<form
					id="contact-form"
					class="grid content-center gap-6 bg-neutral-900/40 px-5 py-12 sm:px-8 sm:py-16 lg:p-12"
					action="/api/contact"
					method="post"
				>
					<div class="mb-2">
						<p class="font-mono text-brand-accent text-xs uppercase">Project inquiry</p>
						<h2 class="mt-3 text-balance font-semibold text-2xl text-white sm:text-3xl">Tell us just enough to begin.</h2>
					</div>
					<div>
						<label class="block font-medium text-sm text-white" for="name">Your name</label>
						<input
							class="mt-2 w-full rounded-sm border border-neutral-700 bg-neutral-950 px-4 py-3.5 text-white outline-none transition-colors duration-150 placeholder:text-neutral-600 focus:border-brand-accent focus:ring-1 focus:ring-brand-accent"
							id="name"
							name="name"
							type="text"
							placeholder="Name or company contact"
							autocomplete="name"
							required
							aria-describedby="name-help"
						/>
						<p id="name-help" class="sr-only">Your name or company contact.</p>
					</div>

					<div>
						<label class="block font-medium text-sm text-white" for="email">Email</label>
						<input
							class="mt-2 w-full rounded-sm border border-neutral-700 bg-neutral-950 px-4 py-3.5 text-white outline-none transition-colors duration-150 placeholder:text-neutral-600 focus:border-brand-accent focus:ring-1 focus:ring-brand-accent"
							id="email"
							name="email"
							type="email"
							placeholder="you@company.com"
							autocomplete="email"
							inputmode="email"
							required
							aria-describedby="email-help"
						/>
						<p id="email-help" class="mt-2 text-neutral-500 text-sm">
							Used only to reply to this inquiry.
						</p>
					</div>

					<div>
						<label class="block font-medium text-sm text-white" for="message">Message</label>
						<textarea
							class="mt-2 min-h-40 w-full resize-y rounded-sm border border-neutral-700 bg-neutral-950 px-4 py-3.5 text-white outline-none transition-colors duration-150 placeholder:text-neutral-600 focus:border-brand-accent focus:ring-1 focus:ring-brand-accent"
							id="message"
							name="message"
							placeholder="What are you working on, and what needs to become clearer?"
							required
							aria-describedby="message-help"
						></textarea>
						<p id="message-help" class="mt-2 text-neutral-500 text-sm">
							Include scope, timing, and any constraints worth knowing before the first reply.
						</p>
					</div>

					<div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>

					<div
						id="contact-success"
						class="hidden rounded-sm border border-emerald-400/40 bg-emerald-400/10 p-4 text-emerald-100 text-sm leading-6"
						tabindex="-1"
						role="status"
					>
						Message sent. Check your inbox for the confirmation email.
					</div>
					<div
						id="contact-error"
						class="hidden rounded-sm border border-red-400/40 bg-red-400/10 p-4 text-red-100 text-sm leading-6"
						tabindex="-1"
						role="alert"
					>
						The message could not be sent. Try again, or email contact@auditmos.com directly.
					</div>

					<button
						id="contact-submit"
						class="rounded-sm bg-brand-accent px-5 py-3.5 font-semibold text-neutral-950 transition-colors duration-150 hover:bg-white focus-visible:outline-2 focus-visible:outline-brand-accent focus-visible:outline-offset-4 disabled:cursor-not-allowed disabled:opacity-60"
						type="submit"
					>
						Send message
					</button>
					<p class="text-pretty text-neutral-500 text-xs leading-5">
						By sending this form, you agree to the handling described in our <a class="underline hover:text-brand-accent" href="/privacy">privacy notice</a>.
					</p>
				</form>
			</div>
		</section>
	</main>
	<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
	<script is:inline>
		const form = document.querySelector("#contact-form");
		const success = document.querySelector("#contact-success");
		const error = document.querySelector("#contact-error");
		const submit = document.querySelector("#contact-submit");

		function showNotice(target, message) {
			success.classList.add("hidden");
			error.classList.add("hidden");
			target.textContent = message;
			target.classList.remove("hidden");
			target.focus();
		}

		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			success.classList.add("hidden");
			error.classList.add("hidden");
			submit.disabled = true;

			const formData = new FormData(form);
			const payload = {
				name: formData.get("name"),
				email: formData.get("email"),
				message: formData.get("message"),
				turnstileToken: formData.get("cf-turnstile-response") ?? "",
			};

			try {
				const response = await fetch("/api/contact", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				});
				const body = await response.json().catch(() => ({}));

				if (response.ok) {
					form.reset();
					globalThis.turnstile?.reset();
					showNotice(success, "Message sent. Check your inbox for the confirmation email.");
					return;
				}

				globalThis.turnstile?.reset();
				showNotice(
					error,
					body.error ?? "The message could not be sent. Try again, or email contact@auditmos.com directly.",
				);
			} catch {
				globalThis.turnstile?.reset();
				showNotice(error, "Network error. Try again, or email contact@auditmos.com directly.");
			} finally {
				submit.disabled = false;
			}
		});
	</script>
</Layout>
