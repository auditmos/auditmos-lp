---
import Layout from "@/layouts/Layout.astro";
import { legalEntity, site } from "@/brand/site";
import { aboutPage } from "@/site/pages";

export const prerender = true;
---

<Layout title={aboutPage.title} description={aboutPage.description} path={aboutPage.path}>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[1.3fr_0.7fr] lg:items-end lg:py-28">
				<div>
					<p class="font-mono text-brand-accent text-xs uppercase">Company / Tallinn, Estonia</p>
					<h1 class="mt-7 max-w-5xl text-balance font-semibold text-5xl text-white leading-[1.03] sm:text-7xl">
						Small by design. Serious about the work.
					</h1>
				</div>
				<p class="max-w-xl text-pretty text-lg text-neutral-300 leading-8">
					Auditmos is an independent technical company for software delivery, applied R&D,
					and security work where judgment, evidence, and clear ownership matter.
				</p>
			</div>
		</section>

		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-7xl gap-12 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[0.6fr_1.4fr] lg:gap-20">
				<div>
					<p class="font-mono text-brand-accent text-xs uppercase">Operating principles</p>
					<h2 class="mt-4 max-w-md text-balance font-semibold text-3xl text-white sm:text-4xl">Clarity should survive the handoff.</h2>
				</div>
				<div class="border-neutral-800 border-t">
					<article class="grid gap-4 border-neutral-800 border-b py-7 sm:grid-cols-[3rem_0.7fr_1.3fr]">
						<span class="font-mono text-brand-accent text-xs">01</span>
						<h3 class="font-semibold text-white text-xl">Substance first</h3>
						<p class="max-w-xl text-pretty text-neutral-400 leading-7">The public claims stay narrow. The useful detail lives in the work, the method, and the artifacts a client receives.</p>
					</article>
					<article class="grid gap-4 border-neutral-800 border-b py-7 sm:grid-cols-[3rem_0.7fr_1.3fr]">
						<span class="font-mono text-brand-accent text-xs">02</span>
						<h3 class="font-semibold text-white text-xl">Technical ownership</h3>
						<p class="max-w-xl text-pretty text-neutral-400 leading-7">Engagements are shaped around explicit outcomes and tradeoffs, with work that another capable team can understand and carry forward.</p>
					</article>
					<article class="grid gap-4 border-neutral-800 border-b py-7 sm:grid-cols-[3rem_0.7fr_1.3fr]">
						<span class="font-mono text-brand-accent text-xs">03</span>
						<h3 class="font-semibold text-white text-xl">Business-aware evidence</h3>
						<p class="max-w-xl text-pretty text-neutral-400 leading-7">Technical output is written so engineering, leadership, procurement, and external reviewers can make the decision in front of them.</p>
					</article>
				</div>
			</div>
		</section>

		<section class="bg-neutral-900/30">
			<div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[0.8fr_1.2fr] lg:gap-20">
				<div>
					<p class="font-mono text-brand-accent text-xs uppercase">Vendor details</p>
					<h2 class="mt-4 text-balance font-semibold text-3xl text-white sm:text-5xl">Easy to verify.</h2>
					<p class="mt-5 max-w-md text-pretty text-neutral-400 leading-7">The details procurement and counterparties usually need, kept in one place.</p>
				</div>
				<dl class="border-neutral-800 border-t">
					<div class="grid grid-cols-[7rem_1fr] border-neutral-800 border-b py-5 sm:grid-cols-[10rem_1fr]"><dt class="text-neutral-500">Legal name</dt><dd class="text-white">{legalEntity.name}</dd></div>
					<div class="grid grid-cols-[7rem_1fr] border-neutral-800 border-b py-5 sm:grid-cols-[10rem_1fr]"><dt class="text-neutral-500">Registration</dt><dd class="text-white tabular-nums">{legalEntity.registration}</dd></div>
					<div class="grid grid-cols-[7rem_1fr] border-neutral-800 border-b py-5 sm:grid-cols-[10rem_1fr]"><dt class="text-neutral-500">VAT</dt><dd class="text-white tabular-nums">{legalEntity.vat}</dd></div>
					<div class="grid grid-cols-[7rem_1fr] border-neutral-800 border-b py-5 sm:grid-cols-[10rem_1fr]"><dt class="text-neutral-500">Address</dt><dd class="text-pretty text-white">{legalEntity.address}</dd></div>
					<div class="grid grid-cols-[7rem_1fr] border-neutral-800 border-b py-5 sm:grid-cols-[10rem_1fr]"><dt class="text-neutral-500">Contact</dt><dd><a class="text-brand-accent hover:text-white" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></dd></div>
				</dl>
			</div>
		</section>
	</main>
</Layout>
