---
import Layout from "@/layouts/Layout.astro";
import { ossProjects } from "@/oss/projects";
import { openSourcePage } from "@/site/pages";

export const prerender = true;

const projects = ossProjects;

const updatedFormatter = new Intl.DateTimeFormat("en", { year: "numeric", month: "short" });
const formatUpdated = (iso: string): string => updatedFormatter.format(new Date(iso));
---

<Layout
	title={openSourcePage.title}
	description={openSourcePage.description}
	path={openSourcePage.path}
>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
				<p class="mb-4 font-medium text-brand-accent text-sm uppercase tracking-[0.18em]">
					Open Source
				</p>
				<h1 class="max-w-4xl text-4xl font-semibold text-white leading-tight sm:text-5xl">
					Public repositories from the Auditmos organization.
				</h1>
				<p class="mt-6 max-w-2xl text-lg text-neutral-300 leading-8">
					Templates, tooling, and audit resources published under
					<a class="text-brand-accent hover:text-white" href="https://github.com/auditmos">
						github.com/auditmos</a>. The list is generated at build time and mirrors what is live
					on GitHub.
				</p>
			</div>
		</section>

		<section>
			<div class="mx-auto max-w-6xl px-6 py-14">
				{
					projects.length === 0 ? (
						<div class="rounded-lg border border-neutral-800 bg-neutral-900/60 p-8 text-center">
							<p class="text-lg text-neutral-300 leading-8">
								Watch our work on{" "}
								<a class="text-brand-accent hover:text-white" href="https://github.com/auditmos">
									github.com/auditmos
								</a>
								.
							</p>
						</div>
					) : (
						<ul class="grid gap-5 md:grid-cols-2">
							{projects.map((project) => (
								<li>
									<a
										class="flex h-full flex-col rounded-lg border border-neutral-800 bg-neutral-900/60 p-6 transition hover:border-brand-accent/70"
										href={project.url}
										rel="noopener"
									>
										<h2 class="text-xl font-semibold text-white">{project.name}</h2>
										{project.description && (
											<p class="mt-3 text-neutral-300 leading-7">{project.description}</p>
										)}
										<div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-neutral-400 text-sm">
											{project.language && (
												<span class="inline-flex items-center gap-1.5">
													<span class="size-2 rounded-full bg-brand-accent" aria-hidden="true" />
													{project.language}
												</span>
											)}
											<span aria-label={`${project.stars} stars`}>★ {project.stars}</span>
											<span>Updated {formatUpdated(project.updatedAt)}</span>
										</div>
									</a>
								</li>
							))}
						</ul>
					)
				}
			</div>
		</section>
	</main>
</Layout>
