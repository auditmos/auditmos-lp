---
import Layout from "@/layouts/Layout.astro";
import { ossProjects } from "@/oss/projects";
import { openSourcePage } from "@/site/pages";

export const prerender = true;

const projects = ossProjects;
const visibleProjects = projects.slice(0, 8);

const updatedFormatter = new Intl.DateTimeFormat("en", { year: "numeric", month: "short" });
const formatUpdated = (iso: string): string => updatedFormatter.format(new Date(iso));
---

<Layout
	title={openSourcePage.title}
	description={openSourcePage.description}
	path={openSourcePage.path}
>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[1.2fr_0.8fr] lg:items-end lg:py-28">
				<div>
					<p class="font-mono text-brand-accent text-xs uppercase">Open source</p>
					<h1 class="mt-7 max-w-5xl text-balance font-semibold text-5xl text-white leading-[1.03] sm:text-7xl">
						Work you can inspect, use, and challenge.
					</h1>
				</div>
				<p class="max-w-xl text-pretty text-lg text-neutral-300 leading-8">
					Templates, tooling, and audit resources published through
					<a class="text-brand-accent hover:text-white" href="https://github.com/auditmos"> github.com/auditmos</a>. This list is generated from what is live on GitHub.
				</p>
			</div>
		</section>

		<section>
			<div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-24">
				{
					projects.length === 0 ? (
						<div class="border border-neutral-800 bg-neutral-900/40 p-8 text-center">
							<p class="text-lg text-neutral-300 leading-8">
								Watch our work on{" "}
								<a class="text-brand-accent hover:text-white" href="https://github.com/auditmos">
									github.com/auditmos
								</a>
								.
							</p>
						</div>
					) : (
						<ul class="grid border-neutral-800 border-t md:grid-cols-2">
							{visibleProjects.map((project) => (
								<li>
									<a
										class="flex h-full min-h-64 flex-col justify-between border-neutral-800 border-b p-6 transition-colors duration-150 hover:bg-neutral-900/60 focus-visible:outline-2 focus-visible:outline-brand-accent md:odd:border-r"
										href={project.url}
										rel="noopener"
									>
										<div><h2 class="text-balance font-semibold text-white text-xl">{project.name}</h2>
										{project.description && (
											<p class="mt-3 text-pretty text-neutral-400 leading-7">{project.description}</p>
										)}
										</div><div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-neutral-500 text-xs">
											{project.language && (
												<span class="inline-flex items-center gap-1.5">
													<span class="size-2 rounded-full bg-brand-accent" aria-hidden="true" />
													{project.language}
												</span>
											)}
											<span class="tabular-nums" aria-label={`${project.stars} stars`}>★ {project.stars}</span>
											<span>Updated {formatUpdated(project.updatedAt)}</span>
										</div>
									</a>
								</li>
							))}
						</ul>
					)
				}
				{visibleProjects.length < projects.length && (
					<div class="mt-10 flex flex-col gap-5 border-neutral-800 border-t pt-8 sm:flex-row sm:items-center sm:justify-between">
						<p class="text-pretty text-neutral-400 text-sm">
							Showing {visibleProjects.length} of {projects.length} public repositories.
						</p>
						<a class="font-semibold text-brand-accent hover:text-white" href="https://github.com/auditmos">
							Explore the full organization <span aria-hidden="true">↗</span>
						</a>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>
