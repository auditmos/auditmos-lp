---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { getClientDisplay, sortProjects } from "@/projects";
import { projectsIndexPage } from "@/site/pages";

export const prerender = true;

const projects = sortProjects(await getCollection("projects"));
---

<Layout
	title={projectsIndexPage.title}
	description={projectsIndexPage.description}
	path={projectsIndexPage.path}
>
	<main>
		<section class="border-neutral-800 border-b">
			<div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 sm:px-8 sm:py-24 lg:grid-cols-[1.25fr_0.75fr] lg:items-end lg:py-28">
				<div>
					<p class="font-mono text-brand-accent text-xs uppercase">Selected work</p>
					<h1 class="mt-7 max-w-5xl text-balance font-semibold text-5xl text-white leading-[1.03] sm:text-7xl">
						Work shown with enough context to judge the fit.
					</h1>
				</div>
				<p class="max-w-xl text-pretty text-lg text-neutral-300 leading-8">
					Named work appears where permission exists. Confidential engagements are described
					by sector, problem, and outcome—without dressing up what cannot be disclosed.
				</p>
			</div>
		</section>

		<section>
			<div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-24">
				<div class="border-neutral-800 border-t">
					{
						projects.map((project, index) => (
							<a
								class="group grid gap-5 border-neutral-800 border-b py-8 transition-colors duration-150 hover:bg-neutral-900/50 focus-visible:outline-2 focus-visible:outline-brand-accent sm:px-5 lg:grid-cols-[4rem_0.8fr_1.2fr_auto] lg:items-center"
								href={`/projects/${project.data.slug}`}
							>
								<span class="font-mono text-neutral-600 text-xs tabular-nums">{String(index + 1).padStart(2, "0")}</span>
								<div>
									<p class="font-mono text-neutral-500 text-xs">
										{getClientDisplay(project.data)}
										{project.data.year && <span class="ml-3 tabular-nums">{project.data.year}</span>}
									</p>
									<h2 class="mt-3 text-balance font-semibold text-2xl text-white">{project.data.title}</h2>
								</div>
								<div>
									<p class="max-w-xl text-pretty text-neutral-400 leading-7">{project.data.summary}</p>
									{project.data.stack.length > 0 && (
										<ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 font-mono text-neutral-500 text-xs">
											{project.data.stack.map((item) => <li>{item}</li>)}
										</ul>
									)}
								</div>
								<span class="text-brand-accent text-xl transition-transform duration-150 group-hover:translate-x-1" aria-hidden="true">→</span>
							</a>
						))
					}
				</div>
			</div>
		</section>
	</main>
</Layout>
