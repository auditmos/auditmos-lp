{
	"name": "auditmos-lp",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.34.4",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"prepare": "simple-git-hooks && wrangler types",
		"init-project": "tsx scripts/init-project.ts",
		"new-project": "tsx scripts/new-project.ts",
		"dev": "astro dev --port 3000",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"types": "astro check && tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:ci": "biome ci .",
		"knip": "knip",
		"release": "semantic-release",
		"release:dry": "semantic-release --dry-run",
		"deps": "taze -r",
		"deps:update": "taze -r -w",
		"deps:major": "taze -r major",
		"deps:major:update": "taze -r major -w"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.5.5",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.2",
		"astro": "^6.4.8",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "2.4.4",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@types/node": "^22.20.0",
		"@vitest/coverage-v8": "^4.1.7",
		"execa": "^9.6.1",
		"knip": "^6.24.0",
		"semantic-release": "^25.0.5",
		"simple-git-hooks": "^2.13.1",
		"taze": "^19.14.1",
		"tsx": "^4.23.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.10",
		"wrangler": "^4.107.0"
	},
	"overrides": {
		"vite": "^7.3.6"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm run lint:ci",
		"pre-push": "pnpm run types && pnpm run knip"
	}
}
