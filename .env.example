# Used by `wrangler` CLI for deploy/secret commands.
# Prefer `wrangler login` for local development.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional. When set at build time, Layout injects Cloudflare Web Analytics.
CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Public Turnstile widget key for prerendered `/contact` builds.
# Runtime secrets still belong in `.dev.vars` / `.staging.vars` / `.production.vars`.
TURNSTILE_SITE_KEY=
