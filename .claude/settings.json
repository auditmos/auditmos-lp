{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "FILE=$(cat - | jq -r '.tool_input.file_path') && case \"$FILE\" in */worker-configuration.d.ts) echo 'BLOCKED: auto-generated. Edit wrangler.jsonc then run pnpm cf-typegen.' >&2; exit 2;; */.astro/*) echo 'BLOCKED: auto-generated by Astro. Run astro sync / astro dev / astro build instead.' >&2; exit 2;; esac"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "FILE=$(cat - | jq -r '.tool_input.file_path') && case \"$FILE\" in *.astro) exit 0;; *) pnpm exec biome check --write --unsafe --skip=correctness/noUnusedImports \"$FILE\";; esac"
					}
				]
			}
		]
	},
	"enabledPlugins": {
		"ask@brainstormer": true,
		"blueprint@brainstormer": true,
		"carve@brainstormer": true,
		"dispatch@brainstormer": true,
		"lean@brainstormer": true,
		"tdd@brainstormer": true,
		"brainstorm@brainstormer": true
	},
	"extraKnownMarketplaces": {
		"brainstormer": {
			"source": {
				"source": "github",
				"repo": "auditmos/brainstormer"
			}
		}
	},
	"permissions": {
		"allow": [
			"Bash(tail:*)",
			"Bash(cat:*)",
			"Bash(grep:*)",
			"Bash(find:*)",
			"Bash(awk:*)",
			"Bash(ls:*)",
			"WebFetch(domain:docs.astro.build)",
			"WebFetch(domain:tailwindcss.com/docs)",
			"WebFetch(domain:developers.cloudflare.com)",
			"WebFetch(domain:hono.dev/docs)",
			"WebFetch(domain:pnpm.io)",
			"WebFetch(domain:vite.dev/guide/)",
			"WebFetch(domain:orm.drizzle.team/docs/overview)",
			"WebFetch(domain:neon.com/docs/introduction)",
			"mcp__ide__getDiagnostics",
			"Bash(pnpm types:*)",
			"Bash(pnpm lint:*)",
			"Bash(pnpm view:*)"
		],
		"deny": ["Bash(rm -rf:*)", "Read(./.env)", "Read(./.env.*)"]
	}
}
